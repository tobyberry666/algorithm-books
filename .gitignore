__pycache__/
*.pyc

# ----------------------------- 前端依赖（本工具无需 node 依赖） -----------------------------
node_modules/

# ----------------------------- 系统 / IDE -----------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ----------------------------- 内部文件 -----------------------------
.agents/
*.log

